<launch>
  <arg name="cmd_vel_topic" default="/cmd_vel"/>
  <arg name="odom_topic" default="/slam/odom"/>
  <arg name="scan_frame" default="base_link"/>
  <arg name="move_forward_only" default="false"/>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen" clear_params="true">
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>

    <rosparam file="$(find mid360_navigation)/config/costmap_common_params.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find mid360_navigation)/config/costmap_common_params.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find mid360_navigation)/config/local_costmap_params.yaml" command="load"/>
    <rosparam file="$(find mid360_navigation)/config/global_costmap_params.yaml" command="load"/>
    <rosparam file="$(find mid360_navigation)/config/move_base_params.yaml" command="load"/>
    <rosparam file="$(find mid360_navigation)/config/dwa_local_planner_params.yaml" command="load"/>

    <!-- Force differential-drive constraints in runtime -->
    <param name="DWAPlannerROS/holonomic_robot" value="false"/>
    <param name="DWAPlannerROS/max_vel_y" value="0.0"/>
    <param name="DWAPlannerROS/min_vel_y" value="0.0"/>
    <param name="DWAPlannerROS/acc_lim_y" value="0.0"/>

    <!-- Override scan source frame at launch time so different SLAM stacks can
         preserve their real sensor origin without forking the YAML. -->
    <param name="global_costmap/obstacle_layer/scan/sensor_frame" value="$(arg scan_frame)"/>
    <param name="local_costmap/obstacle_layer/scan/sensor_frame" value="$(arg scan_frame)"/>

    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>

    <param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)"/>
  </node>
</launch>
