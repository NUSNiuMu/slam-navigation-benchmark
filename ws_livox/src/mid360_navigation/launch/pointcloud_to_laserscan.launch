<launch>
  <arg name="cloud_topic" default="/slam/cloud_registered"/>
  <arg name="scan_topic" default="/scan"/>
  <arg name="target_frame" default="base_link"/>
  <arg name="min_height" default="-0.1"/>
  <arg name="max_height" default="2"/>
  <arg name="transform_tolerance" default="0.2"/>
  <arg name="scan_time" default="0.1"/>
  <arg name="concurrency_level" default="1"/>

  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan" output="screen">
    <remap from="cloud_in" to="$(arg cloud_topic)"/>
    <remap from="scan" to="$(arg scan_topic)"/>
    <param name="target_frame" value="$(arg target_frame)"/>
    <param name="transform_tolerance" value="$(arg transform_tolerance)"/>
    <param name="min_height" value="$(arg min_height)"/>
    <param name="max_height" value="$(arg max_height)"/>
    <param name="angle_min" value="-3.1415926"/>
    <param name="angle_max" value="3.1415926"/>
    <param name="angle_increment" value="0.0087"/>
    <param name="scan_time" value="$(arg scan_time)"/>
    <param name="range_min" value="0.2"/>
    <param name="range_max" value="30.0"/>
    <param name="use_inf" value="true"/>
    <param name="inf_epsilon" value="1.0"/>
    <param name="concurrency_level" value="$(arg concurrency_level)"/>
  </node>
</launch>
